{
  "name": "lifestack-e2e",
  "version": "1.0.0",
  "description": "End-to-end Playwright tests for Lifestack",
  "main": "index.js",
  "scripts": {
    "precheck": "node ./scripts/precheck.mjs",
    "test": "npm run test:full",
    "test:smoke": "npm run precheck && playwright test --grep @smoke",
    "test:full": "npm run precheck && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
